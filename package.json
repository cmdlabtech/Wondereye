{
  "name": "wondereye",
  "version": "1.2.0",
  "private": true,
  "workspaces": [
    "packages/frontend",
    "packages/worker"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "dev:worker": "npm run dev --workspace=packages/worker",
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:frontend\"",
    "dev:sim": "bash scripts/dev-sim.sh",
    "dev:lan": "bash scripts/dev-local.sh",
    "deploy:frontend": "npm run deploy --workspace=packages/frontend",
    "deploy:worker": "npm run deploy --workspace=packages/worker",
    "deploy": "npm run deploy:worker && npm run deploy:frontend",
    "qr": "evenhub qr --http --ip 192.168.86.100 --port 5173",
    "qr:prod": "evenhub qr -u https://wondereye.app/app.html"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.5",
    "concurrently": "^9.0.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.69.0"
  }
}
